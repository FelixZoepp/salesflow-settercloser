{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "^(?!pitchfirst\\.io$)(?!.*\\.vercel\\.app$)(?!localhost)(?!127\\.0\\.0\\.1).+$"
        }
      ],
      "destination": "/api/serve-lead-page"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
