# ============================================
# Caddy Reverse Proxy for Custom Lead Domains
# ============================================
#
# This Caddyfile handles ALL custom domains connected by users.
# Caddy automatically provisions SSL via Let's Encrypt.
#
# How it works:
# 1. User sets A-records pointing to this server's IPs
# 2. Caddy accepts the request on ANY domain (catch-all)
# 3. Caddy forwards to our Supabase Edge Function (serve-lead-page)
# 4. The edge function resolves domain → account → lead → HTML
#
# Deploy: Place this file at /etc/caddy/Caddyfile on the VPS
# Then: sudo systemctl restart caddy

# Global options
{
	# Email for Let's Encrypt notifications
	email admin@salesflow-settercloser.de

	# Enable on-demand TLS for dynamic domains
	on_demand_tls {
		# Ask endpoint: Caddy checks if we should serve this domain
		# Returns 200 if domain is in our custom_domains table
		ask https://dxdknkeexankgtkpeuvt.supabase.co/functions/v1/check-domain-allowed
		# Rate limit new certificate requests
		interval 1m
		burst 5
	}
}

# Catch-all server: handles ANY domain pointing to this IP
# Uses on-demand TLS to automatically get certs for new domains
:443 {
	tls {
		on_demand
	}

	# Log for debugging
	log {
		output file /var/log/caddy/access.log
		format json
	}

	# Forward all requests to our Supabase Edge Function
	reverse_proxy https://dxdknkeexankgtkpeuvt.supabase.co {
		# Rewrite the path to hit the serve-lead-page function
		header_up Host dxdknkeexankgtkpeuvt.supabase.co
		header_up X-Forwarded-Host {http.request.host}
		header_up X-Original-Path {http.request.uri}

		# The actual Supabase Edge Function URL
		rewrite /functions/v1/serve-lead-page

		# Pass the service role key for auth
		header_up Authorization "Bearer {env.SUPABASE_SERVICE_ROLE_KEY}"
	}
}

# HTTP → HTTPS redirect
:80 {
	redir https://{host}{uri} permanent
}
